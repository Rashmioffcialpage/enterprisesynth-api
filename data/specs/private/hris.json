{
  "openapi": "3.0.0",
  "info": {
    "title": "Internal HRIS API",
    "version": "1.0.0"
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Internal-Api-Key"
      }
    }
  },
  "paths": {
    "/employees/{employee_id}/onboard": {
      "post": {
        "operationId": "onboardEmployee",
        "description": "Kick off the onboarding workflow for a newly hired employee: provisions accounts, assigns a manager, and schedules orientation.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "name": "employee_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "start_date",
                  "department",
                  "manager_id"
                ],
                "properties": {
                  "start_date": {
                    "type": "string"
                  },
                  "department": {
                    "type": "string"
                  },
                  "manager_id": {
                    "type": "string"
                  },
                  "employment_type": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/leave-requests": {
      "post": {
        "operationId": "createLeaveRequest",
        "description": "Submit a leave-of-absence request for approval.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "employee_id",
                  "leave_type",
                  "start_date",
                  "end_date"
                ],
                "properties": {
                  "employee_id": {
                    "type": "string"
                  },
                  "leave_type": {
                    "type": "string"
                  },
                  "start_date": {
                    "type": "string"
                  },
                  "end_date": {
                    "type": "string"
                  },
                  "notes": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/leave-requests/{request_id}/approve": {
      "post": {
        "operationId": "approveLeaveRequest",
        "description": "Manager approval for a pending leave request.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "approver_id"
                ],
                "properties": {
                  "approver_id": {
                    "type": "string"
                  },
                  "comment": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/employees/{employee_id}/salary": {
      "get": {
        "operationId": "getEmployeeSalary",
        "description": "Retrieve current compensation details for an employee. Restricted to HR and the employee's manager.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "name": "employee_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/employees/{employee_id}/salary/adjust": {
      "post": {
        "operationId": "adjustEmployeeSalary",
        "description": "Record a compensation change (raise, promotion adjustment, or correction).",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "name": "employee_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "new_annual_salary",
                  "effective_date",
                  "reason"
                ],
                "properties": {
                  "new_annual_salary": {
                    "type": "number"
                  },
                  "effective_date": {
                    "type": "string"
                  },
                  "reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/benefits/enroll": {
      "post": {
        "operationId": "enrollBenefits",
        "description": "Enroll an employee in a benefits plan during open enrollment or a qualifying life event.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "employee_id",
                  "plan_id"
                ],
                "properties": {
                  "employee_id": {
                    "type": "string"
                  },
                  "plan_id": {
                    "type": "string"
                  },
                  "dependents": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}