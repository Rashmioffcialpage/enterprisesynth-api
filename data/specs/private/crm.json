{
  "openapi": "3.0.0",
  "info": {
    "title": "Internal CRM API",
    "version": "1.0.0"
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Internal-Api-Key"
      }
    }
  },
  "paths": {
    "/customers/search": {
      "post": {
        "operationId": "searchCustomers",
        "description": "Search the customer database by name, region, or account tier.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "query"
                ],
                "properties": {
                  "query": {
                    "type": "string"
                  },
                  "region": {
                    "type": "string"
                  },
                  "account_tier": {
                    "type": "string"
                  },
                  "limit": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/customers/{customer_id}/risk": {
      "get": {
        "operationId": "getCustomerRisk",
        "description": "Retrieve the churn-risk score and contributing factors for a customer account.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "name": "customer_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/opportunities": {
      "post": {
        "operationId": "createOpportunity",
        "description": "Create a new sales opportunity tied to a customer account.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "customer_id",
                  "stage",
                  "estimated_value"
                ],
                "properties": {
                  "customer_id": {
                    "type": "string"
                  },
                  "stage": {
                    "type": "string"
                  },
                  "estimated_value": {
                    "type": "number"
                  },
                  "owner_email": {
                    "type": "string"
                  },
                  "close_date": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/opportunities/{opportunity_id}/stage": {
      "patch": {
        "operationId": "updateOpportunityStage",
        "description": "Advance or roll back an opportunity's pipeline stage.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "name": "opportunity_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "stage"
                ],
                "properties": {
                  "stage": {
                    "type": "string"
                  },
                  "reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/contracts/{contract_id}": {
      "get": {
        "operationId": "getContract",
        "description": "Retrieve contract terms, renewal date, and signatory details for a customer contract.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "name": "contract_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/contracts": {
      "post": {
        "operationId": "createContract",
        "description": "Create a new contract record linked to a customer and opportunity.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "customer_id",
                  "term_months",
                  "annual_value"
                ],
                "properties": {
                  "customer_id": {
                    "type": "string"
                  },
                  "opportunity_id": {
                    "type": "string"
                  },
                  "term_months": {
                    "type": "integer"
                  },
                  "annual_value": {
                    "type": "number"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}