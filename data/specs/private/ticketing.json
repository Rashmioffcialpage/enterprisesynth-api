{
  "openapi": "3.0.0",
  "info": {
    "title": "Internal Ticket Management API",
    "version": "1.0.0"
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Internal-Api-Key"
      }
    }
  },
  "paths": {
    "/incidents": {
      "post": {
        "operationId": "createIncident",
        "description": "Open a new incident ticket.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "severity",
                  "reporter_id"
                ],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "severity": {
                    "type": "string"
                  },
                  "reporter_id": {
                    "type": "string"
                  },
                  "affected_service": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/incidents/{incident_id}/escalate": {
      "post": {
        "operationId": "escalateIncident",
        "description": "Escalate an incident to the next on-call tier.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "name": "incident_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "reason"
                ],
                "properties": {
                  "reason": {
                    "type": "string"
                  },
                  "target_tier": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/incidents/{incident_id}/resolve": {
      "post": {
        "operationId": "resolveIncident",
        "description": "Mark an incident resolved and record the root-cause summary.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "name": "incident_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "resolution_summary"
                ],
                "properties": {
                  "resolution_summary": {
                    "type": "string"
                  },
                  "root_cause": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/slas/{sla_id}": {
      "get": {
        "operationId": "getSlaStatus",
        "description": "Retrieve the SLA definition and current breach status for a ticket category.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "name": "sla_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/incidents/{incident_id}/assign": {
      "patch": {
        "operationId": "assignIncident",
        "description": "Reassign an incident to a different responder or team.",
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "parameters": [
          {
            "name": "incident_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "assignee_id"
                ],
                "properties": {
                  "assignee_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}